# tools/hardhat-deploy/.env.example
#
# Copy this file to `.env` (in this same dir) and fill in real values. The
# real `.env` is gitignored — never commit deployer privkeys.
#
# Rule 10: deployer key is forever-Sepolia-only. Never use on a chain that
# holds real value. For mainnet deploys, generate fresh keys and use a
# hardware wallet or keystore.

# RPC URLs — Alchemy is recommended (no rate-limit issues from CI / Brave).
# Match the keys you've already rotated for the frontend (see cyrusthegreat/.env).
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-alchemy-key>
BSC_TESTNET_RPC_URL=https://bnb-testnet.g.alchemy.com/v2/<your-alchemy-key>
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/<your-alchemy-key>

# Deployer privkey (Sepolia-only — same key as cyrusthegreat/.env's WALLET1_PRIVK).
# Used by hardhat to sign the deploy tx. NEVER use this on mainnet.
SEPOLIA_PRIVATE_KEY=0x...

# Block-explorer API keys for source verification (`scripts/verify.ts`).
# Etherscan v2 covers most chains via chainid; BSCScan free tier doesn't (see
# L-009 / TODO.md P2). All three keys can be the same value if you're using
# Etherscan v2 multichain.
ETHERSCAN_API_KEY=<your-etherscan-v2-key>
BSCSCAN_API_KEY=<your-bscscan-key>
BASESCAN_API_KEY=<your-basescan-key>

# Optional overrides for deployCyrusTresor1.ts:
# FEE_COLLECTOR=0x84064947bcD9729872c5Be91D2aE50380Cbd691E   # defaults to WALLET1_PUBK
# SALT=0x...                                                  # auto-generated random if unset
# DRY_RUN=1                                                   # estimate gas only, don't submit
